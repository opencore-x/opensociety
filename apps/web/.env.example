# Copy to `.env` (gitignored) for local web dev. All web vars must be prefixed
# with VITE_ to be exposed to the client bundle.

# Base URL of the API. Defaults to http://localhost:8787 if unset.
VITE_API_URL=http://localhost:8787

# Dev-only stand-in for the authenticated user, until Clerk sessions are wired
# into the web app. When set, it is sent as the `x-user-id` header so writes
# that record an author (e.g. publishing a notice, approving a visitor) work.
# Must be a real users.id (uuid) from your database.
# VITE_DEV_USER_ID=00000000-0000-0000-0000-000000000000
